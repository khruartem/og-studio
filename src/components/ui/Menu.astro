---
import MenuItem from "../ui/MenuItem.astro";
import type { MenuItem as MenuItemType } from "../../data/navigation";

interface Props {
  items: MenuItemType[];
  class?: string;
}

const { items, class: className = "" } = Astro.props as Props;
---

<ul class={className}>
  {items.map((item) => <MenuItem item={item} />)}
</ul>
